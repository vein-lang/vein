<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <AssemblyName>ishtar</AssemblyName>
    <ImplicitUsings>enable</ImplicitUsings>
    <GenerateRequiresPreviewFeaturesAttribute>True</GenerateRequiresPreviewFeaturesAttribute>
    <RuntimeIdentifier Condition="'$(RuntimeIdentifier)' == ''">$(NETCoreSdkRuntimeIdentifier)</RuntimeIdentifier>
    <RuntimeIdentifiers>win-x64;osx-x64;osx-arm64;linux-x64;linux-arm64</RuntimeIdentifiers>
    <ErrorOnDuplicatePublishOutputFiles>false</ErrorOnDuplicatePublishOutputFiles>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='ReleaseAot|AnyCPU'">
    <PublishAot>true</PublishAot>
    <IlcGenerateDgmlFile>true</IlcGenerateDgmlFile>
    <IlcGenerateMapFile>true</IlcGenerateMapFile>
    <IlcSingleThreaded>true</IlcSingleThreaded>
    <IlcDumpGeneratedIL>true</IlcDumpGeneratedIL>
    <Optimize>false</Optimize>
    <IlcGenerateStackTraceData>true</IlcGenerateStackTraceData>
    <IlcTrimMetadata>false</IlcTrimMetadata>
    <IlcDisableReflection>false</IlcDisableReflection>
    <DebugType>embedded</DebugType>
    <DefineConstants>$(DefineConstants);BOEHM_GC;VALIDATE_RUNTIME_TOKEN;USE_MANAGED_COLLECTIONS;DEBUG</DefineConstants>
    <SingleAppImage>false</SingleAppImage>
  </PropertyGroup>

  <PropertyGroup Condition="'$(Configuration)'=='Release'">
    <DebugSymbols>True</DebugSymbols>
    <DebugType>full</DebugType>
    <Optimize>false</Optimize>
    <DebuggerSupport>false</DebuggerSupport>
    <EnableUnsafeUTF7Encoding>false</EnableUnsafeUTF7Encoding>
    <EventSourceSupport>false</EventSourceSupport>
    <HttpActivityPropagationSupport>false</HttpActivityPropagationSupport>
    <InvariantGlobalization>true</InvariantGlobalization>
    <MetadataUpdaterSupport>false</MetadataUpdaterSupport>
    <MetricsSupport>false</MetricsSupport>
    <UseSystemResourceKeys>true</UseSystemResourceKeys>
    <DefineConstants>$(DefineConstants);BOEHM_GC;VALIDATE_RUNTIME_TOKEN;USE_MANAGED_COLLECTIONS;PROFILER;DEBUG;</DefineConstants>
    <PublishSingleFile>true</PublishSingleFile>
    <SelfContained>true</SelfContained>
    <TrimMode>partial</TrimMode>
    <PublishTrimmed>true</PublishTrimmed>
  </PropertyGroup>


  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='LegacyRelease|AnyCPU'">
    <PublishAot>true</PublishAot>
    <Optimize>True</Optimize>
    <TrimMode>link</TrimMode>
    <IlcGenerateStackTraceData>false</IlcGenerateStackTraceData>
    <IlcOptimizationPreference>Size</IlcOptimizationPreference>
    <IlcDisableUnhandledExceptionExperience>true</IlcDisableUnhandledExceptionExperience>
    <DebugType>embedded</DebugType>
    <DefineConstants>$(DefineConstants);BOEHM_GC;VALIDATE_RUNTIME_TOKEN;USE_MANAGED_COLLECTIONS</DefineConstants>
  </PropertyGroup>

  <PropertyGroup Condition="'$(Configuration)'=='Debug'">
    <DebugSymbols>True</DebugSymbols>
    <DebugType>full</DebugType>
    <Optimize>false</Optimize>
    <DefineConstants>$(DefineConstants);BOEHM_GC;VALIDATE_RUNTIME_TOKEN;USE_MANAGED_COLLECTIONS;PROFILER;</DefineConstants>
  </PropertyGroup>

  <!-- libuv native library: copy DLL for Debug/Release (P/Invoke), link static lib for AOT -->
  <PropertyGroup>
    <LibuvOutputDir>$([System.IO.Path]::GetFullPath('$(MSBuildThisFileDirectory)..\..\runtime\libuv\.output\x64'))</LibuvOutputDir>
  </PropertyGroup>

  <Target Name="_CheckLibuvBuilt" BeforeTargets="Build;Publish">
    <Error Condition="!Exists('$(LibuvOutputDir)')"
           Text="libuv output directory not found: $(LibuvOutputDir). Run .\build.libuv.ps1 from the repository root." />
    <Error Condition="('$(Configuration)'=='Debug' Or '$(Configuration)'=='Release') And !Exists('$(LibuvOutputDir)\libuv.dll')"
           Text="libuv.dll not found in $(LibuvOutputDir). Run .\build.libuv.ps1 from the repository root." />
    <Error Condition="('$(Configuration)'=='ReleaseAot' Or '$(Configuration)'=='LegacyRelease') And !Exists('$(LibuvOutputDir)\libuv-static.lib')"
           Text="libuv-static.lib not found in $(LibuvOutputDir). Run .\build.libuv.ps1 from the repository root." />
  </Target>

  <ItemGroup Condition="'$(Configuration)'=='Debug' Or '$(Configuration)'=='Release'">
    <None Include="$(LibuvOutputDir)\libuv.dll" Condition="Exists('$(LibuvOutputDir)\libuv.dll')">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Link>libuv.dll</Link>
    </None>
  </ItemGroup>

  <ItemGroup Condition="'$(Configuration)'=='ReleaseAot' Or '$(Configuration)'=='LegacyRelease'">
    <NativeLibrary Include="$(LibuvOutputDir)\libuv-static.lib" Condition="Exists('$(LibuvOutputDir)\libuv-static.lib')" />
    <DirectPInvoke Include="libuv" />
  </ItemGroup>

  <!-- Boehm GC native library: copy DLL for Debug/Release (P/Invoke), link static lib for AOT -->
  <PropertyGroup>
    <BdwgcOutputDir>$([System.IO.Path]::GetFullPath('$(MSBuildThisFileDirectory)..\..\runtime\bdwgc\.output\x64'))</BdwgcOutputDir>
  </PropertyGroup>

  <Target Name="_CheckBdwgcBuilt" BeforeTargets="Build;Publish">
    <Error Condition="!Exists('$(BdwgcOutputDir)')"
           Text="Boehm GC output directory not found: $(BdwgcOutputDir). Run .\build.bdwgc.ps1 from the repository root." />
    <Error Condition="('$(Configuration)'=='Debug' Or '$(Configuration)'=='Release') And !Exists('$(BdwgcOutputDir)\libgc.dll')"
           Text="libgc.dll not found in $(BdwgcOutputDir). Run .\build.bdwgc.ps1 from the repository root." />
    <Error Condition="('$(Configuration)'=='ReleaseAot' Or '$(Configuration)'=='LegacyRelease') And !Exists('$(BdwgcOutputDir)\libgc-static.lib')"
           Text="libgc-static.lib not found in $(BdwgcOutputDir). Run .\build.bdwgc.ps1 from the repository root." />
  </Target>

  <ItemGroup Condition="'$(Configuration)'=='Debug' Or '$(Configuration)'=='Release'">
    <None Include="$(BdwgcOutputDir)\libgc.dll" Condition="Exists('$(BdwgcOutputDir)\libgc.dll')">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Link>libgc.dll</Link>
    </None>
  </ItemGroup>

  <ItemGroup Condition="'$(Configuration)'=='ReleaseAot' Or '$(Configuration)'=='LegacyRelease'">
    <NativeLibrary Include="$(BdwgcOutputDir)\libgc-static.lib" Condition="Exists('$(BdwgcOutputDir)\libgc-static.lib')" />
    <DirectPInvoke Include="libgc" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Iced" Version="1.21.0" />

    <ProjectReference Include="..\..\lib\capi\capi.csproj" />
    <ProjectReference Include="..\common\vein.common.csproj" />
    <ProjectReference Include="..\ishtar.base\ishtar.base.csproj" />

    <Content Include="boot.ini">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </Content>

    <InternalsVisibleTo Include="ishtar_test" />

    <Using Include="System.Runtime.InteropServices"></Using>
    <Using Include="System.Runtime.CompilerServices"></Using>
    <Using Include="System.Diagnostics"></Using>
    <Using Include="lang.c"></Using>
    <Using Include="System.Diagnostics.CodeAnalysis"></Using>
  </ItemGroup>
</Project>
